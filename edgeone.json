{
  "name": "hexo-blog",
  "caches": [
    {
      "source": "/medias/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/css/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/js/*",
      "cacheTtl": 31536000
    },
    {
      "source": "/libs/*",
      "cacheTtl": 31536000
    },
    {
      "source": "*.png",
      "cacheTtl": 2592000
    },
    {
      "source": "*.jpg",
      "cacheTtl": 2592000
    },
    {
      "source": "*.webp",
      "cacheTtl": 2592000
    },
    {
      "source": "*.gif",
      "cacheTtl": 2592000
    },
    {
      "source": "/search.xml",
      "cacheTtl": 3600
    },
    {
      "source": "/functions/*",
      "cacheTtl": 0
    },
    {
      "source": "/index.html",
      "cacheTtl": 3600
    },
    {
      "source": "/*/index.html",
      "cacheTtl": 3600
    }
  ]
}
